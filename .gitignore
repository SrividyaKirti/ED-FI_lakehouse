# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
ENV/
env/

# Data files
*.csv
*.json
*.xml
*.parquet
data/bronze/**/*
data/silver/**/*
data/gold/**/*
!data/bronze/.gitkeep
!data/bronze/**/.gitkeep
!data/silver/.gitkeep
!data/silver/**/.gitkeep
!data/gold/.gitkeep
!data/gold/**/.gitkeep
# Allow dbt seed CSVs (reference data checked into version control)
!dbt_project/seeds/*.csv

# DuckDB
*.duckdb
*.duckdb.wal
# Allow the Streamlit app's lakehouse database
!streamlit_app/data/lakehouse.duckdb

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

